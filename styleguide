<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mateo — Design System & Style Guide v1.0</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════
   RESET & BASE
   ═══════════════════════════════════════════ */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  /* ── Primary: Lagoon ── */
  --lagoon-900: #14394A;
  --lagoon-800: #1C5068;
  --lagoon-700: #236A88;
  --lagoon-600: #2A7FA5;
  --lagoon-500: #3D93B8;
  --lagoon-400: #5EA9C8;
  --lagoon-300: #88C1D8;
  --lagoon-200: #B5D9E8;
  --lagoon-100: #DFF0F6;
  --lagoon-50:  #EFF8FB;

  /* ── Secondary: Palm ── */
  --palm-900: #1E3D2A;
  --palm-800: #2B5A3D;
  --palm-700: #3A7A54;
  --palm-600: #4E9A6A;
  --palm-500: #62AC7E;
  --palm-400: #7EBD96;
  --palm-300: #A0D1B2;
  --palm-200: #C5E4D1;
  --palm-100: #E2F3E9;
  --palm-50:  #F0F9F3;

  /* ── Accent: Driftwood ── */
  --drift-900: #4A3920;
  --drift-800: #6B5231;
  --drift-700: #917143;
  --drift-600: #B8915A;
  --drift-500: #C6A472;
  --drift-400: #D4B88E;
  --drift-300: #E0CBAB;
  --drift-200: #ECE0CB;
  --drift-100: #F5EFE3;
  --drift-50:  #FAF7F2;

  /* ── Neutrals (brand-tinted) ── */
  --neutral-950: #0F1A1C;
  --neutral-900: #1C2B2E;
  --neutral-800: #2E4347;
  --neutral-700: #435A5E;
  --neutral-600: #5A7175;
  --neutral-500: #72898D;
  --neutral-400: #8FA3A6;
  --neutral-300: #ADBCBE;
  --neutral-200: #CDD7D9;
  --neutral-100: #E8EDED;
  --neutral-50:  #F4F7F7;

  /* ── Semantic ── */
  --success: #3BA55D;
  --success-light: #E8F5ED;
  --warning: #E5A837;
  --warning-light: #FDF4E0;
  --error: #D94444;
  --error-light: #FDECEC;
  --info: #2A7FA5;
  --info-light: #DFF0F6;

  /* ── Surfaces ── */
  --surface-primary: #FFFFFF;
  --surface-secondary: var(--neutral-50);
  --surface-warm: var(--drift-50);
  --surface-overlay: rgba(15, 26, 28, 0.5);

  /* ── Spacing (8px base grid) ── */
  --space-1: 4px;
  --space-2: 8px;
  --space-3: 12px;
  --space-4: 16px;
  --space-5: 20px;
  --space-6: 24px;
  --space-8: 32px;
  --space-10: 40px;
  --space-12: 48px;
  --space-16: 64px;
  --space-20: 80px;
  --space-24: 96px;

  /* ── Radii ── */
  --radius-sm: 6px;
  --radius-md: 10px;
  --radius-lg: 14px;
  --radius-xl: 20px;
  --radius-full: 9999px;

  /* ── Shadows ── */
  --shadow-sm: 0 1px 3px rgba(15,26,28,0.08);
  --shadow-md: 0 4px 12px rgba(15,26,28,0.10);
  --shadow-lg: 0 8px 28px rgba(15,26,28,0.12);
  --shadow-xl: 0 16px 48px rgba(15,26,28,0.16);
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Nunito', -apple-system, BlinkMacSystemFont, sans-serif;
  font-weight: 400;
  font-size: 15px;
  line-height: 1.65;
  color: var(--neutral-900);
  background: var(--surface-primary);
  -webkit-font-smoothing: antialiased;
}

/* ═══════════════════════════════════════════
   LAYOUT
   ═══════════════════════════════════════════ */
.sg-sidebar {
  position: fixed;
  top: 0; left: 0;
  width: 260px;
  height: 100vh;
  background: var(--neutral-950);
  color: var(--neutral-300);
  padding: 32px 0;
  overflow-y: auto;
  z-index: 100;
}

.sg-sidebar-logo {
  padding: 0 28px;
  margin-bottom: 8px;
}

.sg-sidebar-logo-text {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 28px;
  letter-spacing: 0.06em;
  color: white;
}

.sg-sidebar-logo-sub {
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--neutral-500);
  margin-top: -2px;
}

.sg-sidebar-version {
  display: inline-block;
  background: var(--lagoon-600);
  color: white;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.06em;
  padding: 2px 8px;
  border-radius: var(--radius-full);
  margin-left: 28px;
  margin-bottom: 28px;
}

.sg-nav-group { margin-bottom: 22px; }

.sg-nav-group-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--neutral-600);
  padding: 0 28px;
  margin-bottom: 6px;
}

.sg-nav-link {
  display: block;
  padding: 6px 28px;
  font-size: 13px;
  font-weight: 500;
  color: var(--neutral-400);
  text-decoration: none;
  transition: color 0.15s, background 0.15s;
}

.sg-nav-link:hover {
  color: white;
  background: rgba(255,255,255,0.05);
}

.sg-main {
  margin-left: 260px;
  min-height: 100vh;
}

/* ── Section structure ── */
.sg-section {
  padding: 64px 60px;
  border-bottom: 1px solid var(--neutral-100);
}

.sg-section--hero {
  background: var(--lagoon-600);
  color: white;
  padding: 80px 60px;
  position: relative;
  overflow: hidden;
}

.sg-section--hero::before {
  content: '';
  position: absolute;
  top: -100px; right: -80px;
  width: 420px; height: 420px;
  border-radius: 50%;
  background: rgba(255,255,255,0.04);
}

.sg-section--hero::after {
  content: '';
  position: absolute;
  bottom: -60px; left: 120px;
  width: 240px; height: 240px;
  border-radius: 50%;
  background: rgba(78,154,106,0.15);
}

.sg-section--warm { background: var(--drift-50); }
.sg-section--cool { background: var(--lagoon-50); }
.sg-section--dark { background: var(--neutral-950); color: var(--neutral-200); }

.sg-hero-eyebrow {
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  margin-bottom: 14px;
  position: relative; z-index: 1;
}

.sg-hero-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(3rem, 6vw, 4.5rem);
  letter-spacing: 0.04em;
  line-height: 1.0;
  margin-bottom: 16px;
  position: relative; z-index: 1;
}

.sg-hero-sub {
  font-size: 16px;
  color: rgba(255,255,255,0.75);
  max-width: 520px;
  line-height: 1.7;
  position: relative; z-index: 1;
}

.sg-hero-meta {
  margin-top: 32px;
  display: flex;
  gap: 32px;
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  position: relative; z-index: 1;
}

/* ── Content primitives ── */
.sg-section-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--lagoon-600);
  margin-bottom: 10px;
}

.sg-section--dark .sg-section-label { color: var(--lagoon-400); }

.sg-section-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(1.8rem, 3vw, 2.6rem);
  letter-spacing: 0.03em;
  line-height: 1.05;
  color: var(--neutral-900);
  margin-bottom: 12px;
}

.sg-section--dark .sg-section-title { color: white; }

.sg-section-desc {
  font-size: 15px;
  color: var(--neutral-600);
  max-width: 600px;
  line-height: 1.7;
  margin-bottom: 40px;
}

.sg-section--dark .sg-section-desc { color: var(--neutral-400); }

.sg-subsection { margin-bottom: 48px; }
.sg-subsection:last-child { margin-bottom: 0; }

.sg-subsection-title {
  font-family: 'Nunito', sans-serif;
  font-size: 16px;
  font-weight: 800;
  color: var(--neutral-800);
  margin-bottom: 6px;
}

.sg-section--dark .sg-subsection-title { color: var(--neutral-100); }

.sg-subsection-desc {
  font-size: 13.5px;
  color: var(--neutral-500);
  margin-bottom: 20px;
  max-width: 560px;
  line-height: 1.65;
}

/* ── Utility ── */
.sg-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.sg-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
.sg-grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
.sg-grid-5 { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }

.sg-divider {
  border: none;
  border-top: 1px solid var(--neutral-100);
  margin: 40px 0;
}

.sg-section--dark .sg-divider { border-top-color: rgba(255,255,255,0.08); }

.sg-code {
  font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
  font-size: 12px;
  background: var(--neutral-50);
  border: 1px solid var(--neutral-100);
  border-radius: var(--radius-sm);
  padding: 2px 7px;
  color: var(--lagoon-700);
}

.sg-code-block {
  font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
  font-size: 12px;
  line-height: 1.7;
  background: var(--neutral-950);
  color: var(--neutral-300);
  border-radius: var(--radius-md);
  padding: 20px 24px;
  overflow-x: auto;
  margin-top: 12px;
}

.sg-code-block .key { color: var(--lagoon-400); }
.sg-code-block .val { color: var(--drift-400); }
.sg-code-block .cmt { color: var(--neutral-600); }

.sg-note {
  background: var(--info-light);
  border-left: 3px solid var(--info);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  padding: 14px 18px;
  font-size: 13px;
  color: var(--lagoon-800);
  line-height: 1.6;
  margin-top: 16px;
}

.sg-warn {
  background: var(--warning-light);
  border-left: 3px solid var(--warning);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  padding: 14px 18px;
  font-size: 13px;
  color: var(--drift-900);
  line-height: 1.6;
  margin-top: 16px;
}

/* ═══════════════════════════════════════════
   COLOR SWATCHES
   ═══════════════════════════════════════════ */
.sg-swatch-strip {
  display: grid;
  grid-template-columns: repeat(11, 1fr);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.sg-swatch-cell {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 6px;
  font-size: 9px;
  font-weight: 600;
}

.sg-swatch-cell--light { color: rgba(0,0,0,0.5); }
.sg-swatch-cell--dark { color: rgba(255,255,255,0.6); }

.sg-color-card {
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.sg-color-card-swatch {
  height: 80px;
}

.sg-color-card-info {
  background: white;
  padding: 12px 14px;
}

.sg-color-card-name {
  font-size: 12px;
  font-weight: 700;
  color: var(--neutral-800);
}

.sg-color-card-hex {
  font-family: 'SF Mono', monospace;
  font-size: 11px;
  color: var(--neutral-500);
}

/* ═══════════════════════════════════════════
   TYPOGRAPHY SPECIMENS
   ═══════════════════════════════════════════ */
.sg-type-specimen {
  margin-bottom: 24px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--neutral-100);
}

.sg-type-specimen:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

.sg-type-sample {
  margin-bottom: 8px;
}

.sg-type-meta {
  display: flex;
  gap: 20px;
  font-size: 11px;
  color: var(--neutral-400);
  font-weight: 600;
}

.sg-type-meta span { white-space: nowrap; }

/* ═══════════════════════════════════════════
   COMPONENT DEMOS
   ═══════════════════════════════════════════ */
.sg-component-row {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 20px;
}

.sg-component-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--neutral-400);
  width: 100px;
  flex-shrink: 0;
}

/* ── Buttons ── */
.sg-btn {
  font-family: 'Bebas Neue', sans-serif;
  letter-spacing: 0.08em;
  font-size: 15px;
  border: none;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: all 0.15s ease;
  text-decoration: none;
  line-height: 1;
}

.sg-btn--lg { padding: 14px 28px; border-radius: var(--radius-md); font-size: 16px; }
.sg-btn--md { padding: 11px 22px; border-radius: var(--radius-sm); font-size: 15px; }
.sg-btn--sm { padding: 8px 16px; border-radius: var(--radius-sm); font-size: 13px; }

.sg-btn--primary { background: var(--lagoon-600); color: white; }
.sg-btn--primary:hover { background: var(--lagoon-700); }

.sg-btn--secondary { background: var(--palm-600); color: white; }
.sg-btn--secondary:hover { background: var(--palm-700); }

.sg-btn--accent { background: var(--drift-600); color: white; }
.sg-btn--accent:hover { background: var(--drift-700); }

.sg-btn--outline { background: transparent; border: 1.5px solid var(--lagoon-600); color: var(--lagoon-600); }
.sg-btn--outline:hover { background: var(--lagoon-50); }

.sg-btn--ghost { background: transparent; color: var(--lagoon-600); }
.sg-btn--ghost:hover { background: var(--lagoon-50); }

.sg-btn--disabled { background: var(--neutral-200); color: var(--neutral-400); cursor: not-allowed; }

/* ── Inputs ── */
.sg-input-demo {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.sg-input-label {
  font-size: 13px;
  font-weight: 700;
  color: var(--neutral-700);
}

.sg-input {
  font-family: 'Nunito', sans-serif;
  font-size: 14px;
  padding: 11px 14px;
  border: 1.5px solid var(--neutral-200);
  border-radius: var(--radius-sm);
  color: var(--neutral-900);
  background: white;
  outline: none;
  width: 280px;
  transition: border-color 0.15s;
}

.sg-input::placeholder { color: var(--neutral-400); }
.sg-input:focus { border-color: var(--lagoon-600); box-shadow: 0 0 0 3px var(--lagoon-100); }
.sg-input--error { border-color: var(--error); }
.sg-input--error:focus { box-shadow: 0 0 0 3px var(--error-light); }

.sg-input-hint {
  font-size: 12px;
  color: var(--neutral-500);
}

.sg-input-error-text {
  font-size: 12px;
  color: var(--error);
  font-weight: 600;
}

/* ── Cards ── */
.sg-card {
  background: white;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.sg-card-image {
  height: 140px;
  position: relative;
}

.sg-card-tag {
  position: absolute;
  top: 10px; left: 10px;
  background: rgba(255,255,255,0.95);
  border-radius: var(--radius-full);
  padding: 4px 12px;
  font-size: 11px;
  font-weight: 700;
  color: var(--lagoon-700);
}

.sg-card-body { padding: 16px 18px; }

.sg-card-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 18px;
  letter-spacing: 0.04em;
  color: var(--neutral-900);
  margin-bottom: 4px;
}

.sg-card-subtitle {
  font-size: 12.5px;
  color: var(--neutral-500);
  margin-bottom: 12px;
}

.sg-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sg-card-rating {
  display: flex;
  align-items: center;
  gap: 6px;
  color: var(--drift-600);
}

.sg-card-rating svg {
  width: 16px;
  height: 16px;
}

.sg-card-rating span {
  font-family: 'Nunito', sans-serif;
  font-size: 12px;
  font-weight: 700;
  color: var(--neutral-600);
}

/* ── Tags / Badges ── */
.sg-tag {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.04em;
  padding: 4px 12px;
  border-radius: var(--radius-full);
}

.sg-tag--lagoon { background: var(--lagoon-100); color: var(--lagoon-700); }
.sg-tag--palm { background: var(--palm-100); color: var(--palm-700); }
.sg-tag--drift { background: var(--drift-100); color: var(--drift-700); }
.sg-tag--neutral { background: var(--neutral-100); color: var(--neutral-700); }
.sg-tag--success { background: var(--success-light); color: #1E6B35; }
.sg-tag--warning { background: var(--warning-light); color: #8D6518; }
.sg-tag--error { background: var(--error-light); color: #A12B2B; }

/* ── Mobile nav demo ── */
.sg-mobile-frame {
  width: 320px;
  border-radius: 28px;
  border: 6px solid var(--neutral-900);
  overflow: hidden;
  box-shadow: var(--shadow-xl);
  background: white;
}

.sg-mobile-status {
  background: var(--lagoon-600);
  padding: 8px 20px;
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  font-weight: 700;
  color: white;
}

.sg-mobile-header {
  background: var(--lagoon-600);
  padding: 12px 20px 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.sg-mobile-header-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px;
  letter-spacing: 0.06em;
  color: white;
}

.sg-mobile-content {
  padding: 16px;
  min-height: 200px;
  background: var(--neutral-50);
}

.sg-mobile-mini-card {
  background: white;
  border-radius: var(--radius-md);
  padding: 14px 16px;
  box-shadow: var(--shadow-sm);
  margin-bottom: 10px;
  display: flex;
  gap: 12px;
  align-items: center;
}

.sg-mobile-mini-card-thumb {
  width: 48px; height: 48px;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.sg-mobile-mini-card-title {
  font-size: 13px;
  font-weight: 700;
  color: var(--neutral-800);
}

.sg-mobile-mini-card-sub {
  font-size: 11px;
  color: var(--neutral-500);
}

.sg-mobile-tab-bar {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  background: white;
  border-top: 1px solid var(--neutral-100);
  padding: 8px 0 12px;
}

.sg-mobile-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  font-size: 10px;
  font-weight: 600;
  color: var(--neutral-400);
}

.sg-mobile-tab--active { color: var(--lagoon-600); }

.sg-mobile-tab-icon {
  width: 22px; height: 22px;
  border-radius: 50%;
  background: var(--neutral-200);
}

.sg-mobile-tab--active .sg-mobile-tab-icon {
  background: var(--lagoon-100);
}

/* ── Spacing visualization ── */
.sg-spacing-item {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 8px;
}

.sg-spacing-bar {
  height: 20px;
  background: var(--lagoon-200);
  border-radius: 3px;
}

.sg-spacing-label {
  font-family: 'SF Mono', monospace;
  font-size: 11px;
  color: var(--neutral-600);
  width: 100px;
  flex-shrink: 0;
}

.sg-spacing-value {
  font-family: 'SF Mono', monospace;
  font-size: 11px;
  color: var(--neutral-400);
  width: 40px;
}

/* ── Radius visualization ── */
.sg-radius-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.sg-radius-box {
  width: 72px; height: 72px;
  background: var(--lagoon-100);
  border: 2px solid var(--lagoon-400);
}

.sg-radius-name {
  font-family: 'SF Mono', monospace;
  font-size: 10px;
  color: var(--neutral-500);
  text-align: center;
}

/* ── Shadow visualization ── */
.sg-shadow-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}

.sg-shadow-box {
  width: 100px; height: 72px;
  background: white;
  border-radius: var(--radius-md);
}

.sg-shadow-name {
  font-family: 'SF Mono', monospace;
  font-size: 10px;
  color: var(--neutral-500);
  text-align: center;
}

/* ── Icon grid ── */
.sg-icon-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
  gap: 12px;
}

